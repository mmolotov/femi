{
  "name": "@femi/evidence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare:build-metadata": "node ./scripts/write-build-metadata.mjs",
    "prepare:connection": "node ./scripts/write-connection-options.mjs",
    "build": "pnpm prepare:connection && pnpm prepare:build-metadata && evidence build",
    "build:strict": "pnpm prepare:connection && pnpm prepare:build-metadata && evidence build:strict",
    "dev": "pnpm prepare:connection && pnpm prepare:build-metadata && evidence dev --open /",
    "preview": "evidence preview",
    "sources": "pnpm prepare:connection && evidence sources",
    "sources:strict": "pnpm prepare:connection && evidence sources --strict",
    "test": "pnpm prepare:connection && pnpm prepare:build-metadata && evidence build"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0",
    "@steeze-ui/radix-icons": "^1.0.2",
    "@steeze-ui/svelte-icon": "^1.6.2",
    "@steeze-ui/tabler-icons": "^3.3.1",
    "@tidyjs/tidy": "^2.6.1",
    "@uwdata/mosaic-sql": "^0.26.0",
    "@evidence-dev/component-utilities": "^4.0.13",
    "@evidence-dev/core-components": "^5.4.2",
    "@evidence-dev/evidence": "^40.1.8",
    "@evidence-dev/postgres": "^1.0.10",
    "@evidence-dev/preprocess": "^6.0.7",
    "@evidence-dev/sdk": "^4.0.2",
    "@evidence-dev/tailwind": "^3.1.4",
    "@evidence-dev/telemetry": "^2.1.3",
    "@evidence-dev/universal-sql": "^3.0.1",
    "apache-arrow": "^21.1.0",
    "blueimp-md5": "^2.19.0",
    "chroma-js": "^3.2.0",
    "debounce": "^3.0.0",
    "downloadjs": "^1.4.7",
    "echarts": "^6.1.0",
    "echarts-stat": "^1.2.0",
    "export-to-csv": "^1.4.0",
    "git-remote-origin-url": "^4.0.0",
    "nanoid": "^5.1.11",
    "prismjs": "^1.29.0",
    "ssf": "^0.11.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.8.4",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "postcss-load-config": "^6.0.1",
    "svelte": "^4.2.19",
    "svelte-preprocess": "^5.1.3",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "overrides": {
    "axios": "^1.7.4",
    "jsonwebtoken": "9.0.0",
    "sqlite3": "5.1.5",
    "trim@<0.0.3": ">0.0.3"
  }
}
