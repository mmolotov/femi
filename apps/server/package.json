    "fastify": "^5.6.0",
    "grammy": "^1.38.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2"
