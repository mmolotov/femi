NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
# Set true in deployment: the server sits behind Caddy/Cloudflare, so trust the
# proxy for request.ip. Rate limiting keys on Cloudflare's CF-Connecting-IP.
TRUST_PROXY=false
APP_DOMAIN=femi.example.com
EDGE_NETWORK_NAME=edge
WEB_APP_URL=http://localhost:5173
VITE_BACKEND_URL=http://localhost:3001
TELEGRAM_WEBHOOK_URL=
DATABASE_URL=postgres://femi:femi@localhost:5432/femi
BOT_TOKEN=000000000:replace-me
TELEGRAM_BOT_SECRET_TOKEN=replace-me
TELEGRAM_INIT_DATA_EXPIRES_IN=3600
POSTGRES_DB=femi
POSTGRES_USER=femi
POSTGRES_PASSWORD=femi
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=femi-postgres-data
# Internal monitoring dashboard. The app reads MONITORING_DATABASE_URL (a
# read-only DSN); leave empty to fall back to DATABASE_URL in local dev.
# create-monitoring-readonly-user.sh provisions the role from the two DB vars.
MONITORING_DATABASE_URL=
MONITORING_DB_USER=monitoring_femi_readonly
MONITORING_DB_PASSWORD=replace-me
MONITORING_PORT=3002
S3_BACKUP_ENDPOINT=
S3_BACKUP_BUCKET=
S3_BACKUP_REGION=us-east-1
S3_BACKUP_ACCESS_KEY=
S3_BACKUP_SECRET_KEY=
BACKUP_CRON_SCHEDULE="0 3 * * *"
